set tabstop=4
set shiftwidth=4
set smarttab
set expandtab

filetype plugin indent on

set wrap
set showbreak=\ \ \ \ \ \ >
hi NonText guifg=#0030ff ctermfg=green

set ai
set cin

set backspace=2
set wrapmargin=5

set laststatus=2

set foldenable
set foldmethod=indent

set showmatch
set hlsearch
set incsearch
set ignorecase

set listchars=tab:..
set list

set background=dark
set t_Co=256

set pastetoggle=<F2>

set number
syntax on
